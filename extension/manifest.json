{
  "manifest_version": 3,
  "name": "Human Mode",
  "version": "1.0.0",
  "description": "Turn confusing websites into calm, spoken guides.",
  "permissions": ["activeTab", "sidePanel"],
  "action": {
    "default_title": "Open Human Mode",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
